# Sao chép file này thành .env.local rồi điền giá trị thật. Không commit .env.local.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Chuoi ket noi Postgres (cho Supabase CLI chay migration). Vd:
# postgresql://postgres:MAT_KHAU@db.xxxx.supabase.co:5432/postgres
SUPABASE_DB_URL=

# Cloudflare Turnstile (CAPTCHA mien phi) cho form Lien he. De trong khi dev ->
# form van hoat dong, bo qua xac minh. Dang ky mien phi tai cloudflare.com khi
# ra mat that roi dien 2 gia tri nay.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Dia chi that cua website khi deploy (dung cho sitemap.xml, robots.txt, the
# chia se mang xa hoi). De trong khi chay o may -> tu dung http://localhost:3000
# Vi du khi ra mat: https://nguyentuanthinh.com
NEXT_PUBLIC_SITE_URL=
